local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

-- 1. مسح السماء القديمة لمنع التداخل
for _, child in pairs(Lighting:GetChildren()) do
    if child:IsA("Sky") then
        child:Destroy()
    end
end

-- 2. جلب رابط صورة الأفتار الخاص بك (رأس وصدر)
local userId = localPlayer.UserId
local thumbType = Enum.ThumbnailType.AvatarThumbnail
local thumbSize = Enum.ThumbnailSize.Size420x420
local avatarAssetId, isReady = Players:GetUserThumbnailAsync(userId, thumbType, thumbSize)

-- 3. إنشاء سماء جديدة وتطبيق صورتك عليها
if isReady then
    local newSky = Instance.new("Sky", Lighting)
    newSky.SkyboxBk = avatarAssetId
    newSky.SkyboxDn = avatarAssetId
    newSky.SkyboxFt = avatarAssetId
    newSky.SkyboxLf = avatarAssetId
    newSky.SkyboxRt = avatarAssetId
    newSky.SkyboxUp = avatarAssetId
    
    -- إزالة التأثيرات الافتراضية لزيادة وضوح الصورة
    Lighting.CelestialBodiesShown = false
else
    warn("فشل في جلب صورة الأفتار، تأكد من اتصالك بالإنترنت.")
end
